<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg_dark"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="24dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:fontFamily="@font/bruno_ace"
            android:text="NEW ENTRY"
            android:textColor="@color/accent_neon"
            android:textSize="24sp"
            android:layout_marginBottom="24dp"/>

        <EditText
            android:id="@+id/etTankName"
            android:layout_width="match_parent"
            android:layout_height="55dp"
            android:background="@drawable/rounded_input"
            android:hint="Nama Tangki"
            android:padding="12dp"
            android:textColor="@color/text_primary"
            android:textColorHint="@color/text_secondary"
            android:layout_marginBottom="12dp"/>

        <EditText
            android:id="@+id/etPhLevel"
            android:layout_width="match_parent"
            android:layout_height="55dp"
            android:background="@drawable/rounded_input"
            android:hint="Level pH"
            android:padding="12dp"
            android:inputType="numberDecimal"
            android:textColor="@color/text_primary"
            android:textColorHint="@color/text_secondary"
            android:layout_marginBottom="12dp"/>

        <EditText
            android:id="@+id/etNH2Level"
            android:layout_width="match_parent"
            android:layout_height="55dp"
            android:background="@drawable/rounded_input"
            android:hint="Level Amonia (NH3)"
            android:padding="12dp"
            android:inputType="numberDecimal"
            android:textColor="@color/text_primary"
            android:textColorHint="@color/text_secondary"
            android:layout_marginBottom="12dp"/>

        <EditText
            android:id="@+id/etNO2Level"
            android:layout_width="match_parent"
            android:layout_height="55dp"
            android:background="@drawable/rounded_input"
            android:hint="Level Nitrit (NO2)"
            android:padding="12dp"
            android:inputType="numberDecimal"
            android:textColor="@color/text_primary"
            android:textColorHint="@color/text_secondary"
            android:layout_marginBottom="12dp"/>

        <EditText
            android:id="@+id/etNO3Level"
            android:layout_width="match_parent"
            android:layout_height="55dp"
            android:background="@drawable/rounded_input"
            android:hint="Level Nitrat (NO3)"
            android:padding="12dp"
            android:inputType="numberDecimal"
            android:textColor="@color/text_primary"
            android:textColorHint="@color/text_secondary"
            android:layout_marginBottom="12dp"/>

        <EditText
            android:id="@+id/etDescription"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@drawable/rounded_input"
            android:hint="Deskripsi Kondisi"
            android:padding="12dp"
            android:inputType="textMultiLine"
            android:minLines="3"
            android:gravity="top"
            android:textColor="@color/text_primary"
            android:textColorHint="@color/text_secondary"
            android:layout_marginBottom="24dp"/>

        <Button
            android:id="@+id/btnSave"
            android:layout_width="match_parent"
            android:layout_height="60dp"
            android:background="@drawable/rounded_button"
            android:fontFamily="@font/bruno_ace"
            android:text="SIMPAN DATA"
            android:textColor="@color/bg_dark" />
        <!-- ... kode btnSave Anda sebelumnya ... -->

        <TextView
            android:id="@+id/tvHistoryHeader"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="32dp"
            android:layout_marginBottom="16dp"
            android:fontFamily="@font/bruno_ace"
            android:text="HISTORICAL DATA"
            android:textColor="@color/text_secondary"
            android:textSize="16sp"
            android:visibility="gone" />

        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/rvHistory"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:visibility="gone"/>

    </LinearLayout>
</ScrollView>